---
const { slug, variant = '' } = Astro.props as { slug: string; variant?: string };

const iconPaths: Record<string, string> = {
	'folder-size-explorer': `
		<path d="M2 9h8l1.5-2H20a2 2 0 012 2" stroke="#39d7b0" stroke-width="1.4" stroke-linecap="round"/>
		<rect x="2" y="9" width="20" height="12" rx="1.5" stroke="#39d7b0" stroke-width="1.4" fill="rgba(57,215,176,0.07)"/>
		<rect x="5.5" y="14.5" width="2" height="4.5" rx="0.3" fill="#39d7b0"/>
		<rect x="9" y="12.5" width="2" height="6.5" rx="0.3" fill="#65cdf7"/>
		<rect x="12.5" y="13.5" width="2" height="5.5" rx="0.3" fill="#39d7b0" opacity="0.7"/>
		<rect x="16" y="11.5" width="2" height="7.5" rx="0.3" fill="#65cdf7" opacity="0.8"/>`,
	'permission-preserving-file-copier': `
		<path d="M5 3h9l5 5v13a1 1 0 01-1 1H5a1 1 0 01-1-1V4a1 1 0 011-1z" stroke="#39d7b0" stroke-width="1.4" fill="rgba(57,215,176,0.07)"/>
		<path d="M14 3v5h5" stroke="#39d7b0" stroke-width="1.4" fill="none"/>
		<rect x="8" y="13" width="8" height="6" rx="1" stroke="#65cdf7" stroke-width="1.4" fill="rgba(101,205,247,0.07)"/>
		<path d="M10 13v-2a2 2 0 014 0v2" stroke="#65cdf7" stroke-width="1.4" stroke-linecap="round" fill="none"/>
		<circle cx="12" cy="16" r="1" fill="#65cdf7" opacity="0.9"/>`,
	'windows-file-server-permission-auditor': `
		<path d="M12 2l9 4v7c0 5.5-4 9.5-9 11C7 22.5 3 18.5 3 13V6l9-4z" stroke="#65cdf7" stroke-width="1.4" fill="rgba(101,205,247,0.07)"/>
		<path d="M8 13l3 3 5-6" stroke="#39d7b0" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>`,
	'linux-planned': `
		<rect x="3" y="5" width="18" height="14" rx="2" stroke="#f0c36f" stroke-width="1.4" fill="rgba(240,195,111,0.07)"/>
		<path d="M7 9l3 3-3 3" stroke="#f0c36f" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
		<line x1="12" y1="15" x2="17" y2="15" stroke="#f0c36f" stroke-width="1.4" stroke-linecap="round"/>`,
};

const iconHtml = iconPaths[slug] ?? `<circle cx="12" cy="12" r="8" stroke="#39d7b0" stroke-width="1.4" fill="none"/>`;
---

<div class:list={['app-icon', variant && `app-icon--${variant}`]} aria-hidden="true">
	<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" set:html={iconHtml}></svg>
</div>
