---
import AppCard from './AppCard.astro';
import AppIcon from './AppIcon.astro';

interface App {
	name: string;
	slug: string;
	platform: string;
	status: string;
	shortDescription: string;
	icon: string;
	tags: string[];
}

const { title, description, apps = [], id } = Astro.props as {
	title: string;
	description: string;
	apps?: App[];
	id?: string;
};
---

<section id={id}>
	<div class="section-heading">
		<div>
			<p class="eyebrow">Platform</p>
			<h2>{title}</h2>
			<p>{description}</p>
		</div>
	</div>
	{
		apps.length > 0 ? (
			<div class="grid">
				{apps.map((app) => <AppCard app={app} />)}
			</div>
		) : (
			<div class="empty-state">
				<AppIcon slug="linux-planned" />
				<div>
					<h2>Apps coming soon</h2>
					<p>No apps are listed in this category yet. Check back for future releases.</p>
				</div>
			</div>
		)
	}
</section>
