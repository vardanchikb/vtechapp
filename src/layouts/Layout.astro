---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'VTech App | Practical Free Software Utilities',
	description = 'VTech App builds practical free software utilities for Windows users, technicians, and system administrators.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://vtech-app.com');
const currentPath = Astro.url.pathname;
const navItems = [
	{ href: '/', label: 'Home' },
	{ href: '/apps/', label: 'Apps' },
	{ href: '/downloads/', label: 'Downloads' },
	{ href: '/donate/', label: 'Donate' },
	{ href: '/contact/', label: 'Contact' },
	{ href: '/about/', label: 'About' },
];

const isActive = (href: string) => href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" href="/brand/vtech-logo.png" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<link rel="canonical" href={canonical} />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="VTech App" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta name="twitter:card" content="summary" />
		<title>{title}</title>
	</head>
	<body>
		<div class="page-bg" aria-hidden="true"></div>
		<header class="site-header">
			<div class="container nav-shell">
				<a class="brand" href="/" aria-label="VTech App home">
					<img class="brand-logo" src="/brand/vtech-logo.png" alt="" width="42" height="42" />
					<span>
						<strong>VTech App</strong>
						<small>Practical system utilities</small>
					</span>
				</a>
				<nav class="top-nav" aria-label="Main navigation">
					{navItems.map((item) => (
						<a class:list={{ active: isActive(item.href) }} href={item.href}>{item.label}</a>
					))}
				</nav>
			</div>
		</header>

		<div class="container site-info-panel" aria-label="Site information">
			<span>Official site: vtech-app.com</span>
			<span>No accounts</span>
			<span>Static site</span>
			<a href="mailto:vtechinf1@gmail.com">vtechinf1@gmail.com</a>
		</div>

		<main class="container">
			<slot />
		</main>

		<footer class="site-footer">
			<div class="container footer-grid">
				<div>
					<a class="footer-brand" href="/">VTech App</a>
					<p>Independent free software for practical Windows users, technicians, and system administrators.</p>
					<a class="footer-email" href="mailto:vtechinf1@gmail.com">vtechinf1@gmail.com</a>
				</div>
				<nav aria-label="Footer navigation">
					<a href="/apps/">Apps</a>
					<a href="/downloads/">Downloads</a>
					<a href="/donate/">Donate</a>
					<a href="/contact/">Contact</a>
					<a href="/privacy/">Privacy</a>
				</nav>
				<p class="copyright">Copyright &copy; {new Date().getFullYear()} VTech App.</p>
			</div>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		color-scheme: dark;
		--bg: #061014;
		--bg-2: #0a151b;
		--surface: rgba(12, 24, 31, 0.72);
		--surface-2: rgba(15, 31, 39, 0.86);
		--surface-3: #10232c;
		--border: rgba(148, 220, 238, 0.14);
		--border-strong: rgba(148, 220, 238, 0.28);
		--text: #edf7fa;
		--muted: #a1b5bd;
		--soft: #728991;
		--accent: #39d7b0;
		--accent-2: #66cfff;
		--warning: #f3c978;
		--danger: #ff8b8b;
		--container: 1360px;
		--radius-sm: 12px;
		--radius-md: 18px;
		--radius-lg: 26px;
		--shadow-soft: 0 18px 60px rgba(0, 0, 0, 0.24);
		--shadow-card: 0 14px 34px rgba(0, 0, 0, 0.18);
		--space-section: clamp(2.8rem, 5.5vw, 4.75rem);
		font-family: "Aptos", "Segoe UI", "Helvetica Neue", sans-serif;
	}

	* {
		box-sizing: border-box;
	}

	html {
		min-width: 320px;
		background: var(--bg);
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		color: var(--text);
		background:
			radial-gradient(circle at 18% -10%, rgba(57, 215, 176, 0.16), transparent 28rem),
			radial-gradient(circle at 88% 6%, rgba(102, 207, 255, 0.14), transparent 30rem),
			linear-gradient(135deg, var(--bg) 0%, var(--bg-2) 52%, #061014 100%);
		font-size: 15px;
		line-height: 1.58;
		text-rendering: optimizeLegibility;
	}

	body::before {
		position: fixed;
		inset: 0;
		z-index: -2;
		content: "";
		background-image:
			linear-gradient(rgba(102, 207, 255, 0.035) 1px, transparent 1px),
			linear-gradient(90deg, rgba(102, 207, 255, 0.035) 1px, transparent 1px);
		background-size: 52px 52px;
		mask-image: linear-gradient(to bottom, #000 0%, transparent 78%);
	}

	.page-bg {
		position: fixed;
		inset: 0;
		z-index: -3;
		background:
			radial-gradient(circle at 70% 30%, rgba(57, 215, 176, 0.07), transparent 24rem),
			radial-gradient(circle at 25% 70%, rgba(102, 207, 255, 0.06), transparent 22rem);
		pointer-events: none;
	}

	a {
		color: inherit;
	}

	img {
		display: block;
		max-width: 100%;
	}

	h1,
	h2,
	h3,
	p {
		margin-top: 0;
	}

	h1,
	h2,
	h3 {
		line-height: 1.05;
		letter-spacing: -0.045em;
	}

	h1 {
		font-size: clamp(2.15rem, 4.2vw, 4.05rem);
	}

	h2 {
		font-size: clamp(1.38rem, 2.2vw, 2.05rem);
	}

	h3 {
		font-size: clamp(1.02rem, 1.25vw, 1.2rem);
	}

	p {
		color: var(--muted);
	}

	.container {
		width: min(var(--container), calc(100% - clamp(1rem, 4vw, 3rem)));
		margin-inline: auto;
	}

	.site-header {
		position: sticky;
		top: 0;
		z-index: 20;
		border-bottom: 1px solid rgba(148, 220, 238, 0.08);
		background: rgba(6, 16, 20, 0.76);
		backdrop-filter: blur(18px);
	}

	.nav-shell {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.25rem;
		min-height: 68px;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		min-width: max-content;
		text-decoration: none;
	}

	.brand-logo {
		width: 42px;
		height: 42px;
		border-radius: 13px;
		object-fit: cover;
		box-shadow: 0 0 24px rgba(57, 215, 176, 0.13);
	}

	.brand strong,
	.brand small {
		display: block;
	}

	.brand strong {
		font-size: 1rem;
		letter-spacing: -0.02em;
	}

	.brand small {
		color: var(--soft);
		font-size: 0.77rem;
	}

	.top-nav {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 0.25rem;
	}

	.top-nav a,
	.site-footer a {
		border-radius: 999px;
		color: var(--muted);
		text-decoration: none;
		transition: color 160ms ease, background 160ms ease, border-color 160ms ease;
	}

	.top-nav a {
		padding: 0.48rem 0.75rem;
		border: 1px solid transparent;
		font-size: 0.94rem;
	}

	.top-nav a:hover,
	.top-nav a.active {
		border-color: var(--border);
		color: var(--text);
		background: rgba(255, 255, 255, 0.045);
	}

	.site-info-panel {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		align-items: center;
		margin-top: 1rem;
		padding: 0.55rem;
		border: 1px solid var(--border);
		border-radius: 999px;
		background: rgba(6, 16, 20, 0.46);
	}

	.site-info-panel span,
	.site-info-panel a {
		padding: 0.34rem 0.65rem;
		border-radius: 999px;
		color: var(--soft);
		font-size: 0.82rem;
		line-height: 1.2;
		text-decoration: none;
	}

	.site-info-panel span:first-child {
		color: #b9fff0;
		background: rgba(57, 215, 176, 0.08);
	}

	main {
		padding: clamp(1.15rem, 2.4vw, 1.9rem) 0 var(--space-section);
	}

	section {
		margin-top: var(--space-section);
	}

	.page-heading {
		max-width: 820px;
		padding: clamp(2.25rem, 6vw, 4rem) 0 0;
	}

	.page-heading h1 {
		margin-bottom: 1rem;
	}

	.page-heading p,
	.lede {
		max-width: 720px;
		font-size: clamp(1rem, 1.4vw, 1.12rem);
	}

	.eyebrow {
		margin-bottom: 0.75rem;
		color: var(--accent);
		font-size: 0.74rem;
		font-weight: 800;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1.02fr) minmax(330px, 0.98fr);
		gap: clamp(1.5rem, 4vw, 3rem);
		align-items: center;
		margin-top: clamp(1.5rem, 3vw, 2.75rem);
		padding: clamp(1.4rem, 3vw, 2.6rem);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		background:
			linear-gradient(135deg, rgba(12, 24, 31, 0.86), rgba(8, 18, 23, 0.72)),
			radial-gradient(circle at 85% 20%, rgba(102, 207, 255, 0.12), transparent 18rem);
		box-shadow: var(--shadow-soft);
	}

	.home-hero {
		grid-template-columns: minmax(0, 0.72fr) minmax(240px, 0.28fr);
		min-height: clamp(455px, 48vw, 610px);
		padding: clamp(1.35rem, 4vw, 3.65rem);
		background:
			linear-gradient(90deg, rgba(4, 13, 17, 0.95) 0%, rgba(4, 13, 17, 0.84) 35%, rgba(4, 13, 17, 0.38) 64%, rgba(4, 13, 17, 0.18) 100%),
			linear-gradient(180deg, rgba(4, 13, 17, 0.2), rgba(4, 13, 17, 0.58)),
			url("/images/vtech-hero-banner.png");
		background-position: center;
		background-size: cover;
		overflow: hidden;
	}

	.hero-copy {
		position: relative;
		z-index: 1;
		max-width: 620px;
	}

	.hero h1 {
		margin-bottom: 1rem;
		font-size: clamp(2.1rem, 3.9vw, 3.75rem);
	}

	.hero p {
		max-width: 620px;
		font-size: clamp(0.95rem, 1.05vw, 1.03rem);
	}

	.hero-motto {
		display: inline-flex;
		width: fit-content;
		margin-bottom: 1rem;
		padding: 0.45rem 0.75rem;
		border: 1px solid rgba(57, 215, 176, 0.24);
		border-radius: 999px;
		background: rgba(57, 215, 176, 0.08);
		color: #b9fff0;
		font-size: 0.86rem;
		font-weight: 800;
	}

	.hero-actions,
	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		align-items: center;
		margin-top: 1.4rem;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 42px;
		padding: 0.62rem 0.95rem;
		border: 1px solid var(--border-strong);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.045);
		color: var(--text);
		font-size: 0.94rem;
		font-weight: 800;
		line-height: 1.2;
		text-decoration: none;
		transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
	}

	.button:hover {
		transform: translateY(-1px);
		border-color: rgba(102, 207, 255, 0.42);
		background: rgba(255, 255, 255, 0.07);
	}

	.button.primary {
		border-color: rgba(57, 215, 176, 0.54);
		background: linear-gradient(135deg, #39d7b0, #73e8d0);
		color: #03120f;
		box-shadow: 0 12px 34px rgba(57, 215, 176, 0.16);
	}

	.button.disabled,
	button[disabled] {
		cursor: not-allowed;
		transform: none;
		border-color: rgba(243, 201, 120, 0.25);
		background: rgba(243, 201, 120, 0.09);
		color: var(--warning);
		box-shadow: none;
	}

	.category-chips {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-top: 1.35rem;
	}

	.category-chips a,
	.category-chips span {
		display: inline-flex;
		align-items: center;
		min-height: 34px;
		padding: 0.42rem 0.68rem;
		border: 1px solid var(--border);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.035);
		color: var(--muted);
		font-size: 0.86rem;
		font-weight: 700;
		text-decoration: none;
	}

	.hero-visual {
		position: relative;
		min-height: clamp(300px, 34vw, 430px);
		margin: 0;
		overflow: hidden;
		border: 1px solid var(--border-strong);
		border-radius: calc(var(--radius-lg) - 6px);
		background:
			linear-gradient(135deg, rgba(16, 35, 44, 0.95), rgba(6, 16, 20, 0.95)),
			radial-gradient(circle at 65% 36%, rgba(57, 215, 176, 0.16), transparent 16rem);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
	}

	.hero-visual img {
		width: 100%;
		height: 100%;
		min-height: clamp(300px, 34vw, 430px);
		object-fit: cover;
	}

	.hero-visual-card {
		position: absolute;
		right: 1rem;
		bottom: 1rem;
		left: 1rem;
		padding: 0.9rem 1rem;
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
		background: rgba(6, 16, 20, 0.72);
		backdrop-filter: blur(14px);
	}

	.hero-visual-card strong {
		display: block;
		margin-bottom: 0.2rem;
		font-size: 0.96rem;
	}

	.hero-visual-card span {
		color: var(--muted);
		font-size: 0.9rem;
	}

	.grid,
	.feature-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.two-column,
	.catalog-panel {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	.stack {
		display: grid;
		gap: 0.85rem;
	}

	.card,
	.app-card,
	.notice,
	.download-row,
	.form-card,
	.hero-panel,
	.feature-pill {
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 0.035), transparent 42%),
			var(--surface);
		box-shadow: var(--shadow-card);
	}

	.card,
	.app-card,
	.notice,
	.form-card,
	.hero-panel,
	.feature-pill {
		padding: clamp(1.1rem, 2vw, 1.45rem);
	}

	.card h2,
	.card h3,
	.app-card h3,
	.notice h2,
	.section-heading h2 {
		margin-bottom: 0.65rem;
	}

	.section-heading {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 1.15rem;
	}

	.section-heading p {
		max-width: 680px;
		margin-bottom: 0;
	}

	.feature-strip {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0.8rem;
		margin-top: 1rem;
	}

	.feature-pill {
		min-height: 112px;
	}

	.feature-pill strong {
		display: block;
		margin-bottom: 0.25rem;
		color: var(--accent-2);
		font-size: 1.05rem;
		letter-spacing: -0.02em;
	}

	.feature-pill span {
		color: var(--muted);
		font-size: 0.92rem;
	}

	.app-card {
		display: grid;
		align-content: start;
		gap: 0.9rem;
		transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
	}

	.app-card:hover {
		transform: translateY(-2px);
		border-color: var(--border-strong);
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 0.045), transparent 42%),
			var(--surface-2);
	}

	.app-card img {
		width: 48px;
		height: 48px;
		border-radius: 14px;
	}

	.app-card p,
	.card p,
	.notice p,
	.download-row p,
	.meta,
	.site-footer p {
		color: var(--muted);
	}

	.status,
	.tag {
		display: inline-flex;
		width: fit-content;
		align-items: center;
		border: 1px solid rgba(243, 201, 120, 0.26);
		border-radius: 999px;
		background: rgba(243, 201, 120, 0.09);
		color: var(--warning);
		font-size: 0.74rem;
		font-weight: 850;
		line-height: 1.2;
		padding: 0.28rem 0.52rem;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		margin: 0.9rem 0 0;
		padding: 0;
		list-style: none;
	}

	.tag {
		border-color: var(--border);
		background: rgba(102, 207, 255, 0.07);
		color: #aee9ff;
	}

	.catalog-stat {
		display: grid;
		min-height: 160px;
		place-items: center;
		text-align: center;
	}

	.catalog-stat strong {
		display: block;
		color: var(--accent);
		font-size: clamp(2.8rem, 6vw, 4.8rem);
		line-height: 1;
		letter-spacing: -0.08em;
	}

	.catalog-stat span {
		color: var(--muted);
		font-weight: 800;
	}

	.detail-shell {
		max-width: 980px;
		margin-inline: auto;
	}

	.meta-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.7rem;
	}

	.meta-item {
		padding: 0.8rem;
		border: 1px solid var(--border);
		border-radius: var(--radius-sm);
		background: rgba(255, 255, 255, 0.03);
	}

	.meta-item span {
		display: block;
		color: var(--soft);
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.meta-item strong {
		display: block;
		margin-top: 0.25rem;
		color: var(--text);
	}

	.final-cta {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 1rem;
		align-items: center;
		padding: clamp(1.4rem, 3vw, 2rem);
		border: 1px solid var(--border-strong);
		border-radius: var(--radius-lg);
		background:
			radial-gradient(circle at 12% 0%, rgba(57, 215, 176, 0.12), transparent 18rem),
			linear-gradient(135deg, rgba(16, 35, 44, 0.9), rgba(7, 16, 20, 0.82));
		box-shadow: var(--shadow-card);
	}

	.final-cta p {
		margin-bottom: 0;
	}

	.hero-panel {
		display: grid;
		gap: 0.75rem;
		align-content: start;
		min-height: auto;
		background:
			linear-gradient(145deg, rgba(16, 35, 44, 0.82), rgba(7, 16, 20, 0.82)),
			linear-gradient(45deg, transparent 0 48%, rgba(102, 207, 255, 0.08) 48% 52%, transparent 52% 100%);
	}

	.terminal-bar {
		display: flex;
		gap: 0.4rem;
		padding-bottom: 0.65rem;
		border-bottom: 1px solid var(--border);
	}

	.terminal-bar span {
		width: 0.55rem;
		height: 0.55rem;
		border-radius: 50%;
		background: var(--accent);
		box-shadow: 1rem 0 0 var(--warning), 2rem 0 0 var(--accent-2);
	}

	.terminal-line {
		margin: 0;
		color: var(--muted);
		font-family: "Cascadia Code", "SFMono-Regular", Consolas, monospace;
		font-size: 0.88rem;
		line-height: 1.5;
	}

	.terminal-line strong {
		color: var(--accent);
	}

	.download-row {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 1rem;
		align-items: center;
		padding: 1.1rem;
	}

	.download-row h3 {
		margin: 0.55rem 0 0.35rem;
	}

	.gallery {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	.gallery img {
		width: 100%;
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
		background: var(--surface-3);
	}

	form {
		display: grid;
		gap: 1rem;
	}

	label {
		display: grid;
		gap: 0.4rem;
		color: var(--muted);
		font-weight: 760;
	}

	input,
	select,
	textarea {
		width: 100%;
