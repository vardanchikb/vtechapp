---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'VTech App | Practical Free Software Utilities',
	description = 'VTech App builds practical free software utilities for Windows users, technicians, and system administrators.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://vtech-app.com');
const navItems = [
	{ href: '/', label: 'Home' },
	{ href: '/apps/', label: 'Apps' },
	{ href: '/downloads/', label: 'Downloads' },
	{ href: '/donate/', label: 'Donate' },
	{ href: '/contact/', label: 'Contact' },
	{ href: '/about/', label: 'About' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/brand/vtech-logo.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<link rel="canonical" href={canonical} />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="VTech App" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta name="twitter:card" content="summary" />
		<title>{title}</title>
	</head>
	<body>
		<div class="ambient ambient-one"></div>
		<div class="ambient ambient-two"></div>
		<div class="site-shell">
			<header class="site-header">
				<a class="brand" href="/" aria-label="VTech App home">
					<img class="brand-logo" src="/brand/vtech-logo.svg" alt="" width="46" height="46" />
					<span>
						<strong>VTech App</strong>
						<small>Practical system utilities</small>
					</span>
				</a>
				<nav class="top-nav" aria-label="Main navigation">
					{navItems.map((item) => <a href={item.href}>{item.label}</a>)}
				</nav>
			</header>
			<div class="site-info-panel" aria-label="Site information">
				<span>Official site: vtech-app.com</span>
				<span>No accounts or login</span>
				<span>Downloads coming soon</span>
				<a href="mailto:vtechinf1@gmail.com">vtechinf1@gmail.com</a>
			</div>
			<main>
				<slot />
			</main>
			<footer class="site-footer">
				<div>
					<strong>VTech App</strong>
					<p>Independent free software for practical system work. Contact: <a href="mailto:vtechinf1@gmail.com">vtechinf1@gmail.com</a></p>
				</div>
				<nav aria-label="Footer navigation">
					<a href="/apps/">Apps</a>
					<a href="/downloads/">Downloads</a>
					<a href="/privacy/">Privacy</a>
					<a href="/contact/">Contact</a>
					<a href="/donate/">Donate</a>
				</nav>
				<p class="copyright">Copyright &copy; {new Date().getFullYear()} VTech App.</p>
			</footer>
		</div>
	</body>
</html>

<style is:global>
	:root {
		color-scheme: dark;
		--bg: #071014;
		--bg-soft: #0c181e;
		--panel: rgba(17, 32, 39, 0.82);
		--panel-strong: #12242c;
		--line: rgba(131, 232, 255, 0.16);
		--line-strong: rgba(131, 232, 255, 0.32);
		--text: #edf8fb;
		--muted: #9fb7bf;
		--accent: #37d7a1;
		--accent-2: #75d6ff;
		--warning: #f7c873;
		--shadow: 0 24px 80px rgba(0, 0, 0, 0.38);
		font-family: "Aptos", "Segoe UI", "Helvetica Neue", sans-serif;
	}

	* {
		box-sizing: border-box;
	}

	html {
		background: var(--bg);
	}

	body {
		min-width: 320px;
		margin: 0;
		color: var(--text);
		background:
			radial-gradient(circle at top left, rgba(55, 215, 161, 0.2), transparent 32rem),
			radial-gradient(circle at 85% 8%, rgba(117, 214, 255, 0.18), transparent 28rem),
			linear-gradient(135deg, #061014 0%, #0a151b 42%, #071014 100%);
		line-height: 1.6;
	}

	.ambient {
		position: fixed;
		z-index: -2;
		border-radius: 999px;
		filter: blur(10px);
		opacity: 0.7;
		pointer-events: none;
	}

	.ambient-one {
		top: 90px;
		right: 7vw;
		width: 220px;
		height: 220px;
		background: radial-gradient(circle, rgba(55, 215, 161, 0.18), transparent 68%);
	}

	.ambient-two {
		bottom: 12vh;
		left: 4vw;
		width: 280px;
		height: 280px;
		background: radial-gradient(circle, rgba(117, 214, 255, 0.12), transparent 70%);
	}

	body::before {
		position: fixed;
		inset: 0;
		z-index: -1;
		content: "";
		background-image:
			linear-gradient(rgba(117, 214, 255, 0.035) 1px, transparent 1px),
			linear-gradient(90deg, rgba(117, 214, 255, 0.035) 1px, transparent 1px);
		background-size: 44px 44px;
		mask-image: linear-gradient(to bottom, #000, transparent 80%);
	}

	a {
		color: inherit;
	}

	img {
		display: block;
		max-width: 100%;
	}

	.site-shell {
		width: min(1180px, calc(100% - 32px));
		margin: 0 auto;
	}

	.site-header {
		position: sticky;
		top: 0;
		z-index: 5;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
		padding: 24px 0;
		backdrop-filter: blur(18px);
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 12px;
		text-decoration: none;
	}

	.brand-logo {
		width: 46px;
		height: 46px;
		border-radius: 14px;
		box-shadow: 0 0 28px rgba(55, 215, 161, 0.12);
	}

	.brand strong,
	.brand small {
		display: block;
	}

	.brand small {
		color: var(--muted);
		font-size: 0.78rem;
	}

	.top-nav {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 8px;
	}

	.top-nav a,
	.site-footer a {
		border: 1px solid transparent;
		border-radius: 999px;
		color: var(--muted);
		text-decoration: none;
	}

	.top-nav a {
		padding: 8px 12px;
	}

	.top-nav a:hover,
	.site-footer a:hover,
	.site-info-panel a:hover {
		border-color: var(--line);
		color: var(--text);
		background: rgba(255, 255, 255, 0.04);
	}

	.site-info-panel {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		align-items: center;
		margin-bottom: 10px;
		padding: 10px;
		border: 1px solid var(--line);
		border-radius: 999px;
		background: rgba(7, 16, 20, 0.66);
		backdrop-filter: blur(18px);
	}

	.site-info-panel span,
	.site-info-panel a {
		display: inline-flex;
		align-items: center;
		min-height: 30px;
		padding: 5px 10px;
		border-radius: 999px;
		color: var(--muted);
		font-size: 0.86rem;
		text-decoration: none;
	}

	.site-info-panel span:first-child {
		color: var(--accent);
		background: rgba(55, 215, 161, 0.08);
	}

	main {
		padding: 24px 0 56px;
	}

	section {
		margin-top: 56px;
	}

	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
		gap: 28px;
		align-items: stretch;
		padding: 46px;
		border: 1px solid var(--line);
		border-radius: 34px;
		background:
			linear-gradient(135deg, rgba(12, 24, 30, 0.92), rgba(11, 22, 27, 0.74)),
			radial-gradient(circle at top right, rgba(55, 215, 161, 0.18), transparent 25rem);
		box-shadow: var(--shadow);
	}

	.hero.visual-hero {
		grid-template-columns: minmax(0, 0.95fr) minmax(360px, 1.05fr);
		padding: 32px;
	}

	.hero-copy {
		padding: 18px 0 18px 14px;
	}

	.hero-motto {
		display: inline-flex;
		width: fit-content;
		margin: 18px 0 0;
		padding: 10px 14px;
		border: 1px solid rgba(55, 215, 161, 0.34);
		border-radius: 999px;
		background: rgba(55, 215, 161, 0.09);
		color: var(--accent);
		font-weight: 900;
		letter-spacing: -0.01em;
	}

	.hero-visual {
		position: relative;
		min-height: 420px;
		overflow: hidden;
		border: 1px solid var(--line-strong);
		border-radius: 28px;
		background: var(--panel-strong);
	}

	.hero-visual img {
		width: 100%;
		height: 100%;
		min-height: 420px;
		object-fit: cover;
	}

	.hero-visual-card {
		position: absolute;
		right: 18px;
		bottom: 18px;
		left: 18px;
		display: grid;
		gap: 6px;
		padding: 16px;
		border: 1px solid var(--line);
		border-radius: 20px;
		background: rgba(7, 16, 20, 0.78);
		backdrop-filter: blur(14px);
	}

	.hero-visual-card strong {
		color: var(--text);
	}

	.hero-visual-card span {
		color: var(--muted);
	}

	.hero h1,
	.page-heading h1 {
		max-width: 850px;
		margin: 0;
		font-size: clamp(2.45rem, 7vw, 5.5rem);
		line-height: 0.96;
		letter-spacing: -0.075em;
	}

	.hero p,
	.page-heading p,
	.lede {
		max-width: 760px;
		color: var(--muted);
		font-size: 1.08rem;
	}

	.eyebrow {
		margin: 0 0 14px;
		color: var(--accent);
		font-size: 0.76rem;
		font-weight: 800;
		letter-spacing: 0.18em;
		text-transform: uppercase;
	}

	.hero-panel,
	.card,
	.app-card,
	.notice,
	.download-row,
	.form-card {
		border: 1px solid var(--line);
		border-radius: 24px;
		background: var(--panel);
		box-shadow: 0 14px 46px rgba(0, 0, 0, 0.2);
	}

	.hero-panel {
		display: grid;
		align-content: end;
		min-height: 300px;
		padding: 26px;
		background:
			linear-gradient(145deg, rgba(18, 36, 44, 0.92), rgba(9, 19, 24, 0.92)),
			linear-gradient(45deg, transparent 0 48%, rgba(117, 214, 255, 0.18) 48% 52%, transparent 52% 100%);
	}

	.terminal-window {
		align-content: start;
		gap: 14px;
		overflow: hidden;
	}

	.terminal-bar {
		display: flex;
		gap: 7px;
		padding-bottom: 12px;
		border-bottom: 1px solid var(--line);
	}

	.terminal-bar span {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		background: var(--accent);
		box-shadow: 18px 0 0 var(--warning), 36px 0 0 var(--accent-2);
	}

	.terminal-line {
		margin: 0;
		color: var(--muted);
		font-family: "Cascadia Code", "SFMono-Regular", Consolas, monospace;
		font-size: 0.92rem;
	}

	.terminal-line strong {
		color: var(--accent);
		font-weight: 800;
	}

	.hero-actions,
	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		margin-top: 24px;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 44px;
		padding: 10px 16px;
		border: 1px solid var(--line-strong);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.04);
		color: var(--text);
		font-weight: 800;
		text-decoration: none;
	}

	.button.primary {
		border-color: rgba(55, 215, 161, 0.42);
		background: linear-gradient(135deg, var(--accent), #6af0c7);
		color: #03110d;
	}

	.button.disabled,
	button[disabled] {
		cursor: not-allowed;
		border-color: rgba(247, 200, 115, 0.25);
		background: rgba(247, 200, 115, 0.1);
		color: var(--warning);
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 18px;
	}

	.two-column {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 18px;
	}

	.card,
	.app-card,
	.notice,
	.form-card {
		padding: 24px;
	}

	.card,
	.app-card,
	.notice,
	.download-row,
	.form-card {
		position: relative;
		overflow: hidden;
	}

	.card::before,
	.app-card::before,
	.notice::before,
	.download-row::before,
	.form-card::before {
		position: absolute;
		inset: 0;
		content: "";
		background: linear-gradient(135deg, rgba(255, 255, 255, 0.08), transparent 34%);
		opacity: 0.45;
		pointer-events: none;
	}

	.card h2,
	.card h3,
	.app-card h3,
	.notice h2,
	.section-heading h2 {
		margin-top: 0;
		line-height: 1.1;
		letter-spacing: -0.035em;
	}

	.section-heading {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 16px;
		margin-bottom: 18px;
	}

	.section-heading p,
	.card p,
	.app-card p,
	.notice p,
	.meta,
	.download-row p,
	.site-footer p {
		color: var(--muted);
	}

	.app-card {
		display: flex;
		flex-direction: column;
		gap: 14px;
		transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
	}

	.app-card:hover {
		transform: translateY(-3px);
		border-color: var(--line-strong);
		background: rgba(18, 36, 44, 0.92);
	}

	.app-card img {
		width: 56px;
		height: 56px;
		border-radius: 16px;
	}

	.status,
	.tag {
		display: inline-flex;
		width: fit-content;
		align-items: center;
		border: 1px solid rgba(247, 200, 115, 0.26);
		border-radius: 999px;
		background: rgba(247, 200, 115, 0.09);
		color: var(--warning);
		font-size: 0.78rem;
		font-weight: 800;
		padding: 4px 9px;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		margin: 16px 0 0;
		padding: 0;
		list-style: none;
	}

	.tag {
		border-color: var(--line);
		background: rgba(117, 214, 255, 0.08);
		color: var(--accent-2);
	}

	.download-row {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 16px;
		align-items: center;
		padding: 20px;
	}

	.stack {
		display: grid;
		gap: 16px;
	}

	.feature-strip {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 12px;
		margin-top: 18px;
	}

	.feature-pill {
		border: 1px solid var(--line);
		border-radius: 18px;
		background: rgba(255, 255, 255, 0.035);
		padding: 16px;
	}

	.feature-pill strong {
		display: block;
		color: var(--accent-2);
		font-size: 1.2rem;
	}

	.feature-pill span {
		color: var(--muted);
		font-size: 0.9rem;
	}

	.category-chips {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		margin-top: 22px;
	}

	.category-chips a,
	.category-chips span {
		display: inline-flex;
		align-items: center;
		min-height: 38px;
		padding: 8px 12px;
		border: 1px solid var(--line);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.035);
		color: var(--muted);
		font-weight: 800;
		text-decoration: none;
	}

	.category-chips a:hover {
		border-color: var(--line-strong);
		color: var(--text);
	}

	.catalog-panel {
		display: grid;
		grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
		gap: 18px;
	}

	.catalog-stat {
		display: grid;
		place-items: center;
		min-height: 180px;
		text-align: center;
	}

	.catalog-stat strong {
		display: block;
		color: var(--accent);
		font-size: clamp(3rem, 8vw, 5.6rem);
		line-height: 1;
		letter-spacing: -0.08em;
	}

	.catalog-stat span {
		color: var(--muted);
		font-weight: 800;
	}

	.gallery {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 18px;
	}

	.gallery img {
		width: 100%;
		border: 1px solid var(--line);
		border-radius: 22px;
		background: var(--panel-strong);
	}

	form {
		display: grid;
		gap: 16px;
	}

	label {
		display: grid;
		gap: 7px;
		color: var(--muted);
		font-weight: 700;
	}

	input,
	select,
	textarea {
		width: 100%;
		border: 1px solid var(--line);
		border-radius: 14px;
		background: rgba(2, 8, 10, 0.58);
		color: var(--text);
		font: inherit;
		padding: 12px 14px;
	}

	textarea {
		min-height: 160px;
		resize: vertical;
	}

	.site-footer {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 18px;
		align-items: center;
		padding: 30px 0 42px;
		border-top: 1px solid var(--line);
	}

	.site-footer nav {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.site-footer a {
		padding: 7px 10px;
	}

	.copyright {
		grid-column: 1 / -1;
		margin: 0;
		font-size: 0.9rem;
	}

	@media (max-width: 820px) {
		.site-header,
		.site-footer,
		.section-heading {
			align-items: flex-start;
			flex-direction: column;
		}

		.hero,
		.hero.visual-hero,
		.grid,
		.two-column,
		.gallery {
			grid-template-columns: 1fr;
		}

		.catalog-panel {
			grid-template-columns: 1fr;
		}

		.feature-strip {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.hero {
			padding: 28px;
		}

		.hero-copy {
			padding: 0;
		}

		.download-row {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 520px) {
		.feature-strip {
			grid-template-columns: 1fr;
		}
	}
</style>
