---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'VTech App | Practical Free Software Utilities',
	description = 'VTech App builds practical free software utilities for Windows users, technicians, and system administrators.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://vtech-app.com');
const currentPath = Astro.url.pathname;
const navItems = [
	{ href: '/', label: 'Home' },
	{ href: '/apps/', label: 'Apps' },
	{ href: '/downloads/', label: 'Downloads' },
	{ href: '/donate/', label: 'Donate' },
	{ href: '/contact/', label: 'Contact' },
	{ href: '/about/', label: 'About' },
];

const isActive = (href: string) => href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" href="/brand/vtech-logo.png" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<link rel="canonical" href={canonical} />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="VTech App" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta name="twitter:card" content="summary" />
		<title>{title}</title>
	</head>
	<body>
		<a class="skip-link" href="#main-content">Skip to content</a>
		<div class="page-bg" aria-hidden="true"></div>
		<header class="site-header">
			<div class="container nav-shell">
				<a class="brand" href="/" aria-label="VTech App home">
					<img class="brand-logo" src="/brand/vtech-logo.png" alt="" width="40" height="40" />
					<span>
						<strong>VTech App</strong>
						<small>Practical system utilities</small>
					</span>
				</a>
				<button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false" aria-controls="main-nav">
					<svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
						<line x1="2" y1="5" x2="18" y2="5" />
						<line x1="2" y1="10" x2="18" y2="10" />
						<line x1="2" y1="15" x2="18" y2="15" />
					</svg>
				</button>
				<nav id="main-nav" class="top-nav" aria-label="Main navigation">
					{navItems.map((item) => (
						<a class:list={{ active: isActive(item.href) }} href={item.href}>{item.label}</a>
					))}
				</nav>
			</div>
		</header>

		<main id="main-content" class="container">
			<slot />
		</main>

		<footer class="site-footer">
			<div class="container footer-grid">
				<div>
					<a class="footer-brand" href="/">VTech App</a>
					<p>Independent free software for practical Windows users, technicians, and system administrators.</p>
					<a class="footer-email" href="mailto:vtechinf1@gmail.com">vtechinf1@gmail.com</a>
				</div>
				<nav aria-label="Footer navigation">
					<a href="/apps/">Apps</a>
					<a href="/downloads/">Downloads</a>
					<a href="/donate/">Donate</a>
					<a href="/contact/">Contact</a>
					<a href="/privacy/">Privacy</a>
				</nav>
				<p class="copyright">Copyright &copy; {new Date().getFullYear()} VTech App.</p>
			</div>
		</footer>
		<script src="/nav.js" defer></script>
	</body>
</html>

<style is:global>
	:root {
		color-scheme: dark;
		--bg: #050d12;
		--bg-2: #08151c;
		--surface: rgba(12, 24, 31, 0.78);
		--surface-2: rgba(15, 31, 40, 0.92);
		--surface-3: #0f222c;
		--border: rgba(148, 220, 238, 0.14);
		--border-strong: rgba(148, 220, 238, 0.26);
		--text: #edf7fa;
		--muted: #a8bac1;
		--soft: #8ea5af;
		--accent: #39d7b0;
		--accent-2: #65cdf7;
		--warning: #f0c36f;
		--danger: #ff8b8b;
		--container: 1180px;
		--radius-sm: 10px;
		--radius-md: 14px;
		--radius-lg: 20px;
		--shadow-soft: 0 18px 55px rgba(0, 0, 0, 0.28);
		--shadow-card: 0 14px 34px rgba(0, 0, 0, 0.18);
		--space-1: 0.5rem;
		--space-2: 0.75rem;
		--space-3: 1rem;
		--space-4: 1.35rem;
		--space-5: 2rem;
		--space-6: clamp(2.6rem, 5vw, 4.6rem);
		font-family: "Segoe UI", "Helvetica Neue", Arial, sans-serif;
	}

	* {
		box-sizing: border-box;
	}

	html {
		min-width: 320px;
		background: var(--bg);
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		color: var(--text);
		background:
			radial-gradient(circle at 16% -8%, rgba(57, 215, 176, 0.12), transparent 28rem),
			radial-gradient(circle at 86% 4%, rgba(101, 205, 247, 0.11), transparent 30rem),
			linear-gradient(135deg, var(--bg), var(--bg-2) 55%, #050d12);
		font-size: 15px;
		line-height: 1.58;
		text-rendering: optimizeLegibility;
	}

	body::before {
		position: fixed;
		inset: 0;
		z-index: -2;
		content: "";
		background-image:
			linear-gradient(rgba(101, 205, 247, 0.027) 1px, transparent 1px),
			linear-gradient(90deg, rgba(101, 205, 247, 0.027) 1px, transparent 1px);
		background-size: 56px 56px;
		mask-image: linear-gradient(to bottom, #000 0%, transparent 72%);
	}

	.page-bg {
		position: fixed;
		inset: 0;
		z-index: -3;
		background:
			radial-gradient(circle at 72% 28%, rgba(57, 215, 176, 0.06), transparent 24rem),
			radial-gradient(circle at 24% 74%, rgba(101, 205, 247, 0.05), transparent 20rem);
		pointer-events: none;
	}

	a {
		color: inherit;
	}

	img {
		display: block;
		max-width: 100%;
	}

	h1,
	h2,
	h3,
	p {
		margin-top: 0;
	}

	h1,
	h2,
	h3 {
		line-height: 1.08;
		letter-spacing: -0.025em;
	}

	h1 {
		font-size: clamp(2.2rem, 4.2vw, 4rem);
	}

	h2 {
		font-size: clamp(1.35rem, 2.25vw, 2.1rem);
	}

	h3 {
		font-size: clamp(1.02rem, 1.25vw, 1.18rem);
	}

	p {
		color: var(--muted);
	}

	.skip-link {
		position: absolute;
		top: -100%;
		left: 1rem;
		z-index: 100;
		padding: 0.5rem 1rem;
		border-radius: var(--radius-sm);
		background: var(--accent);
		color: #03120f;
		font-weight: 800;
		text-decoration: none;
		transition: top 160ms ease;
	}

	.skip-link:focus {
		top: 1rem;
	}

	.container {
		width: min(var(--container), calc(100% - clamp(1rem, 4vw, 2.75rem)));
		margin-inline: auto;
	}

	.site-header {
		position: sticky;
		top: 0;
		z-index: 20;
		border-bottom: 1px solid rgba(148, 220, 238, 0.09);
		background: rgba(5, 13, 18, 0.82);
		backdrop-filter: blur(18px);
	}

	.nav-shell {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-4);
		min-height: 68px;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.72rem;
		min-width: max-content;
		text-decoration: none;
	}

	.brand-logo {
		width: 40px;
		height: 40px;
		border-radius: 11px;
		object-fit: cover;
		box-shadow: 0 0 24px rgba(57, 215, 176, 0.14);
	}

	.brand strong,
	.brand small {
		display: block;
	}

	.brand strong {
		font-size: 0.98rem;
		letter-spacing: -0.015em;
	}

	.brand small {
		color: var(--soft);
		font-size: 0.75rem;
	}

	.top-nav {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 0.2rem;
	}

	.top-nav a,
	.site-footer a {
		border-radius: 999px;
		color: var(--muted);
		text-decoration: none;
		transition: color 160ms ease, background 160ms ease, border-color 160ms ease, transform 160ms ease;
	}

	.top-nav a {
		padding: 0.42rem 0.68rem;
		border: 1px solid transparent;
		font-size: 0.9rem;
	}

	.top-nav a:hover,
	.top-nav a.active {
		border-color: var(--border);
		color: var(--text);
		background: rgba(255, 255, 255, 0.045);
	}

	.nav-toggle {
		display: none;
		padding: 0.45rem 0.55rem;
		border: 1px solid var(--border);
		border-radius: var(--radius-sm);
		background: transparent;
		color: var(--text);
		cursor: pointer;
		line-height: 1;
	}

	main {
		padding: clamp(1.1rem, 2.4vw, 1.8rem) 0 var(--space-6);
	}

	section {
		margin-top: var(--space-6);
	}

	.page-heading {
		max-width: 780px;
		padding: clamp(2.2rem, 5vw, 4.4rem) 0 0;
	}

	.page-heading h1 {
		margin-bottom: 0.9rem;
	}

	.page-heading p,
	.lede {
		max-width: 700px;
		font-size: clamp(0.98rem, 1.25vw, 1.08rem);
	}

	.eyebrow,
	.badge {
		color: var(--accent);
		font-size: 0.72rem;
		font-weight: 800;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.eyebrow {
		margin-bottom: 0.65rem;
	}

	.badge {
		display: inline-flex;
		width: fit-content;
		margin-bottom: 0.85rem;
		padding: 0.36rem 0.62rem;
		border: 1px solid rgba(57, 215, 176, 0.22);
		border-radius: 999px;
		background: rgba(57, 215, 176, 0.08);
		color: #b9fff0;
		letter-spacing: 0.08em;
	}

	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(280px, 0.8fr);
		gap: clamp(1rem, 3vw, 2.4rem);
		align-items: center;
		margin-top: clamp(1.2rem, 3vw, 2.6rem);
		padding: clamp(1.25rem, 3vw, 2.4rem);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		background:
			linear-gradient(135deg, rgba(12, 24, 31, 0.9), rgba(7, 17, 23, 0.76)),
			radial-gradient(circle at 85% 18%, rgba(101, 205, 247, 0.11), transparent 18rem);
		box-shadow: var(--shadow-soft);
	}

	.home-hero {
		position: relative;
		display: block;
		min-height: clamp(360px, 38vw, 500px);
		padding: clamp(1.45rem, 4vw, 3rem);
		background:
			linear-gradient(90deg, rgba(4, 13, 17, 0.96) 0%, rgba(4, 13, 17, 0.9) 34%, rgba(4, 13, 17, 0.58) 62%, rgba(4, 13, 17, 0.22) 100%),
			linear-gradient(180deg, rgba(4, 13, 17, 0.2), rgba(4, 13, 17, 0.56)),
			url("/images/hero-system-utilities.webp"),
			radial-gradient(circle at 75% 24%, rgba(57, 215, 176, 0.18), transparent 18rem),
			linear-gradient(135deg, #0f222c, #071117);
		background-position: center right;
		background-size: cover;
		overflow: hidden;
	}

	.hero-copy {
		position: relative;
		z-index: 1;
		max-width: 610px;
	}

	.home-hero .hero-copy {
		max-width: min(670px, 58%);
	}

	.hero h1 {
		margin-bottom: 0.82rem;
		font-size: clamp(1.75rem, 2.5vw, 2.55rem);
		line-height: 1.14;
	}

	.hero p {
		max-width: 610px;
		font-size: clamp(0.98rem, 1.1vw, 1.06rem);
	}

	.home-hero .hero p {
		max-width: 580px;
	}

	.hero-actions,
	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.7rem;
		align-items: center;
		margin-top: 1.25rem;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 40px;
		padding: 0.58rem 0.9rem;
		border: 1px solid var(--border-strong);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.045);
		color: var(--text);
		font-size: 0.9rem;
		font-weight: 800;
		line-height: 1.2;
		text-decoration: none;
		transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
	}

	.button:hover {
		transform: translateY(-1px);
		border-color: rgba(101, 205, 247, 0.42);
		background: rgba(255, 255, 255, 0.07);
	}

	.button.primary {
		border-color: rgba(57, 215, 176, 0.55);
		background: linear-gradient(135deg, #39d7b0, #72e6cf);
		color: #03120f;
		box-shadow: 0 12px 30px rgba(57, 215, 176, 0.15);
	}

	.button.disabled,
	button[disabled] {
		cursor: not-allowed;
		transform: none;
		border-color: rgba(240, 195, 111, 0.26);
		background: rgba(240, 195, 111, 0.09);
		color: var(--warning);
		box-shadow: none;
	}

	.grid,
	.feature-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.two-column,
	.roadmap-grid,
	.contact-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	.stack {
		display: grid;
		gap: 0.85rem;
	}

	.card,
	.app-card,
	.notice,
	.form-card,
	.hero-panel,
	.feature-pill,
	.empty-state,
	.release-row {
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 0.035), transparent 42%),
			var(--surface);
		box-shadow: var(--shadow-card);
	}

	.card,
	.app-card,
	.notice,
	.form-card,
	.hero-panel,
	.feature-pill,
	.empty-state {
		padding: clamp(1rem, 1.8vw, 1.35rem);
	}

	.card h2,
	.card h3,
	.app-card h3,
	.notice h2,
	.section-heading h2,
	.form-card h2 {
		margin-bottom: 0.6rem;
	}

	.section-heading {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 1rem;
	}

	.section-heading p {
		max-width: 680px;
		margin-bottom: 0;
	}

	.feature-strip {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0.85rem;
	}

	.feature-pill {
		min-height: 124px;
	}

	.feature-pill strong {
		display: block;
		margin-bottom: 0.25rem;
		color: var(--accent-2);
		font-size: 1rem;
		letter-spacing: -0.015em;
	}

	.feature-pill span {
		color: var(--muted);
		font-size: 0.9rem;
	}

	.app-card {
		display: grid;
		align-content: start;
		gap: 0.8rem;
		min-height: 100%;
		transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
	}

	.app-card:hover {
		transform: translateY(-2px);
		border-color: var(--border-strong);
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 0.045), transparent 42%),
			var(--surface-2);
	}

	.app-card p,
	.card p,
	.notice p,
	.download-row p,
	.release-row p,
	.form-card p,
	.meta,
	.site-footer p {
		color: var(--muted);
	}

	.app-card h3 {
		margin: 0.55rem 0 0.42rem;
	}

	.app-icon {
		display: grid;
		width: 52px;
		height: 52px;
		place-items: center;
		border: 1px solid rgba(148, 220, 238, 0.18);
		border-radius: 14px;
		background: linear-gradient(135deg, rgba(57, 215, 176, 0.1), rgba(15, 34, 44, 0.96));
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06), 0 12px 26px rgba(0, 0, 0, 0.2);
	}

	.app-icon svg {
		width: 26px;
		height: 26px;
	}

	.status,
	.tag {
		display: inline-flex;
		width: fit-content;
		align-items: center;
		border: 1px solid rgba(240, 195, 111, 0.26);
		border-radius: 999px;
		background: rgba(240, 195, 111, 0.09);
		color: var(--warning);
		font-size: 0.72rem;
		font-weight: 850;
		line-height: 1.2;
		padding: 0.26rem 0.5rem;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin: 0.75rem 0 0;
		padding: 0;
		list-style: none;
	}

	.tag {
		border-color: var(--border);
		background: rgba(101, 205, 247, 0.07);
		color: #aee9ff;
	}

	.roadmap-card {
		display: grid;
		align-content: start;
		gap: 0.4rem;
	}

	.roadmap-card .button,
	.roadmap-card .status {
		margin-top: 0.65rem;
	}

	.empty-state {
		display: flex;
		gap: 1rem;
		align-items: center;
		min-height: 150px;
		background:
			linear-gradient(135deg, rgba(57, 215, 176, 0.06), transparent 42%),
			var(--surface);
	}

	.release-table {
		display: grid;
		gap: 0.65rem;
	}

	.release-table-head,
	.release-row {
		display: grid;
		grid-template-columns: minmax(260px, 1fr) 110px 125px 120px 90px;
		gap: 0.9rem;
		align-items: center;
	}

	.release-table-head {
		padding: 0 1rem;
		color: var(--soft);
		font-size: 0.72rem;
		font-weight: 850;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	.release-row {
		padding: 1rem;
	}

	.release-row h3 {
		margin-bottom: 0.25rem;
	}

	.release-row p {
		margin-bottom: 0;
		font-size: 0.9rem;
	}

	.meta-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.65rem;
	}

	.meta-item {
		padding: 0.72rem;
		border: 1px solid var(--border);
		border-radius: var(--radius-sm);
		background: rgba(255, 255, 255, 0.03);
	}

	.meta-item span {
		display: block;
		color: var(--soft);
		font-size: 0.72rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.meta-item strong {
		display: block;
		margin-top: 0.22rem;
		color: var(--text);
	}

	.detail-shell {
		max-width: 980px;
		margin-inline: auto;
	}

	.hero-panel {
		display: grid;
		gap: 0.8rem;
		align-content: start;
	}

	.final-cta {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 1rem;
		align-items: center;
		padding: clamp(1.2rem, 2.5vw, 1.8rem);
		border: 1px solid var(--border-strong);
		border-radius: var(--radius-lg);
		background:
			radial-gradient(circle at 14% 0%, rgba(57, 215, 176, 0.12), transparent 18rem),
			linear-gradient(135deg, rgba(15, 34, 44, 0.9), rgba(7, 17, 23, 0.82));
		box-shadow: var(--shadow-card);
	}

	.final-cta p {
		margin-bottom: 0;
	}

	form {
		display: grid;
		gap: 0.9rem;
	}

	label {
		display: grid;
		gap: 0.36rem;
		color: var(--muted);
		font-weight: 760;
	}

	input,
	select,
	textarea {
		width: 100%;
		border: 1px solid var(--border);
		border-radius: var(--radius-sm);
		background: rgba(2, 8, 10, 0.5);
		color: var(--text);
		font: inherit;
		padding: 0.7rem 0.78rem;
	}

	textarea {
		min-height: 138px;
		resize: vertical;
	}

	.contact-guidance {
		display: grid;
		align-content: start;
		gap: 0.65rem;
	}

	.contact-guidance h3 {
		margin: 0.8rem 0 0;
	}

	.gallery {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	.gallery img {
		width: 100%;
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
		background: var(--surface-3);
	}

	.preview-card {
		min-height: 220px;
		padding: 1.1rem;
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
		background:
			radial-gradient(circle at 78% 10%, rgba(57, 215, 176, 0.14), transparent 13rem),
			linear-gradient(135deg, rgba(15, 34, 44, 0.92), rgba(7, 17, 23, 0.86));
