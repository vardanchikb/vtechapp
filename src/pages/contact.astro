---
import Layout from '../layouts/Layout.astro';
import apps from '../data/apps.json';

const contactEmail = 'contact@vtech-app.com';
---

<Layout
	title="Contact and Feedback | VTech App"
	description="Send feedback, feature requests, bug reports, and support questions to VTech App."
>
	<header class="page-heading">
		<p class="eyebrow">Contact</p>
		<h1>Feedback and support.</h1>
		<p>
			Send practical feedback, feature requests, bug reports, and support questions directly to
			VTech App.
		</p>
	</header>

	<section class="contact-grid">
		<form id="contact-form" class="form-card" action="https://api.web3forms.com/submit" method="post" novalidate>
			<input type="hidden" name="access_key" value="528f82b8-dea6-429f-8e6d-f663c1e41d19" />
			<input type="hidden" name="from_name" value="VTech App Contact Form" />
			<input type="hidden" name="subject" value="VTech App — Contact Form Submission" />
			<input type="checkbox" name="botcheck" style="display:none" />

			<div>
				<h2>Feedback form</h2>
				<p>Fill in the form and your message is sent directly to VTech App.</p>
			</div>
			<label>
				Name
				<input name="name" autocomplete="name" required />
			</label>
			<label>
				Email
				<input type="email" name="email" autocomplete="email" required />
			</label>
			<label>
				App name
				<select name="app-name" autocomplete="off">
					<option value="">General / not app-specific</option>
					{apps.map((app) => <option value={app.name}>{app.name}</option>)}
				</select>
			</label>
			<label>
				Feedback type
				<select name="feedback-type" autocomplete="off" required>
					<option>General feedback</option>
					<option>Feature request</option>
					<option>Bug report</option>
					<option>Support question</option>
					<option>Donation/support question</option>
				</select>
			</label>
			<label>
				Message
				<textarea name="message" required></textarea>
			</label>
			<button class="button primary" type="submit">Send message</button>
			<div id="form-result" class="form-result" role="status" aria-live="polite"></div>
		</form>

		<aside class="notice contact-guidance">
			<h2>Direct contact</h2>
			<p>
				Email VTech App directly at <a href={`mailto:${contactEmail}`}>{contactEmail}</a>.
			</p>
			<a class="button" href={`mailto:${contactEmail}`}>Email VTech App</a>

			<h3>For bug reports</h3>
			<p>
				Include the app name, Windows version, what you expected, what happened, and the steps
				that reproduce the problem.
			</p>

			<h3>For feature requests</h3>
			<p>
				Describe the workflow, the files or systems involved, and how the utility should help.
			</p>

			<h3>Privacy note</h3>
			<p>
				This site has no accounts or database. Do not send passwords, private tokens, license
				keys, or sensitive data through the form.
			</p>
		</aside>
	</section>
</Layout>
