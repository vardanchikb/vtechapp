---
import Layout from '../../layouts/Layout.astro';
import PlatformSection from '../../components/PlatformSection.astro';
import apps from '../../data/apps.json';

const windowsApps = apps.filter((app) => app.platform === 'Windows');
const linuxApps = apps.filter((app) => app.platform === 'Linux');
---

<Layout
	title="Apps | VTech App"
	description="Browse VTech App software utilities by platform. Windows utilities are coming soon and Linux utilities are planned."
>
	<header class="page-heading">
		<p class="eyebrow">Software catalog</p>
		<h1>Practical utilities by platform.</h1>
		<p>
			VTech App is building a focused catalog of practical utilities for system work. Windows
			apps are in development, and Linux apps are planned.
		</p>
	</header>

	<PlatformSection
		title="Windows Apps"
		description="Practical utilities for Windows users, technicians, and system administrators."
		apps={windowsApps}
	/>

	<PlatformSection
		title="Linux Apps"
		description="Linux utilities are planned for future releases."
		apps={linuxApps}
	/>
</Layout>
