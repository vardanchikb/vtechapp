---
import Layout from '../../layouts/Layout.astro';
import PlatformSection from '../../components/PlatformSection.astro';
import apps from '../../data/apps.json';

const windowsApps = apps.filter((app) => app.platform === 'Windows');
const linuxApps = apps.filter((app) => app.platform === 'Linux');
---

<Layout
	title="Apps | VTech App"
	description="Browse VTech App software utilities by platform. Windows and Linux utilities are published as practical tools for real system work."
>
	<header class="page-heading">
		<p class="eyebrow">Software catalog</p>
		<h1>Practical utilities by platform.</h1>
		<p>
			VTech App is building a focused catalog of practical utilities for system work across
			Windows and Linux.
		</p>
	</header>

	<PlatformSection
		title="Windows Apps"
		description="Practical utilities for Windows users, technicians, and system administrators."
		apps={windowsApps}
	/>

	<PlatformSection
		id="linux"
		title="Linux Apps"
		description="Self-hosted Linux utilities for monitoring, automation, and system workflows."
		apps={linuxApps}
	/>
</Layout>
