---
import Layout from '../../layouts/Layout.astro';
import AppIcon from '../../components/AppIcon.astro';
import apps from '../../data/apps.json';

export function getStaticPaths() {
	return apps.map((app) => ({
		params: { slug: app.slug },
		props: { app },
	}));
}

const { app } = Astro.props;
const hasSource = Boolean(app.sourceUrl);
const hasDownload = Boolean(app.downloadUrl);
---

<Layout
	title={`${app.name} | VTech App`}
	description={app.shortDescription}
>
	<article class="detail-shell">
		<header class="hero">
			<div>
				<p class="eyebrow">{app.platform} app</p>
				<h1>{app.name}</h1>
				<p>{app.shortDescription}</p>
				<div class="hero-actions">
					<span class="status">{app.status}</span>
					{hasDownload ? <a class="button primary" href={app.downloadUrl}>Download</a> : null}
					<a class="button primary" href={app.donationUrl} rel="noopener noreferrer">Donate</a>
					<a class="button" href={`mailto:${app.supportEmail}`}>Contact support</a>
				</div>
			</div>
			<aside class="hero-panel">
				<AppIcon slug={app.slug} variant="lg" />
				<div class="meta-grid">
					<div class="meta-item"><span>Platform</span><strong>{app.platform}</strong></div>
					<div class="meta-item"><span>Status</span><strong>{app.status}</strong></div>
					<div class="meta-item"><span>Version</span><strong>{app.currentVersion}</strong></div>
					<div class="meta-item"><span>Release</span><strong>{app.releaseDate}</strong></div>
				</div>
				{
					hasDownload ? (
						<a class="button primary" href={app.downloadUrl}>Download</a>
					) : (
						<span class="button disabled" aria-disabled="true">Download Coming Soon</span>
					)
				}
			</aside>
		</header>

		<section class="two-column">
			<div class="card">
				<h2>About this app</h2>
				<p>{app.longDescription}</p>
				<ul class="tags" aria-label={`${app.name} tags`}>
					{app.tags.map((tag) => <li class="tag">{tag}</li>)}
				</ul>
			</div>
			<div class="card">
				<h2>Release status</h2>
				{
					hasDownload ? (
						<p>This app is available from the official VTech App download link.</p>
					) : (
						<p>
							This app is in development. The download button will remain disabled until an official
							build is available from VTech App.
						</p>
					)
				}
			</div>
		</section>

		<section>
			<div class="section-heading">
				<div>
					<p class="eyebrow">Preview</p>
					<h2>Workflow preview</h2>
					<p>Abstract interface previews show the type of workflow this utility is designed for.</p>
				</div>
			</div>
			<div class="gallery preview-gallery">
				<article class="preview-card">
					<div class="preview-lines" aria-hidden="true"><span></span><span></span><span></span></div>
					<h3>Analyze</h3>
					<p>Review the relevant file, folder, storage, or permission data clearly.</p>
				</article>
				<article class="preview-card">
					<div class="preview-nodes" aria-hidden="true"><span></span><span></span><span></span></div>
					<h3>Act</h3>
					<p>Use focused utility workflows for practical administration tasks.</p>
				</article>
			</div>
		</section>

		<section class="two-column">
			<div class="card">
				<h2>Changelog</h2>
				<ul>
					{app.changelog.map((entry) => <li>{entry}</li>)}
				</ul>
			</div>
			<div class="card">
				<h2>Source URL</h2>
				{
					hasSource ? (
						<a class="button" href={app.sourceUrl} rel="noopener noreferrer">View source</a>
					) : (
						<p class="meta">No public source URL is available yet.</p>
					)
				}
			</div>
		</section>
	</article>
</Layout>
