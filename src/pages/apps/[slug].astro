---
import Layout from '../../layouts/Layout.astro';
import AppIcon from '../../components/AppIcon.astro';
import apps from '../../data/apps.json';

export function getStaticPaths() {
	return apps.map((app) => ({
		params: { slug: app.slug },
		props: { app },
	}));
}

const { app } = Astro.props;
const hasSource = Boolean(app.sourceUrl);
const hasDownload = Boolean(app.downloadUrl);
const isGitHub = hasSource && app.sourceUrl.includes('github.com');
const isGitHubRelease = hasDownload && app.downloadUrl.includes('github.com') && app.downloadUrl.includes('/releases/');
const cloneUrl = isGitHub ? app.sourceUrl + '.git' : null;
const features = app.features ?? [];
const hasChecksum = Boolean(app.checksumUrl);
const olderVersions = app.olderVersions ?? [];
const hasOlderVersions = olderVersions.length > 0;
const featureHeading = app.featureHeading ?? 'Built for practical administration work';
const featureIntro = app.featureIntro ?? 'Focused controls make practical administration workflows easier to review, verify, and finish.';
const screenshots = (app.screenshots ?? []).map((screenshot) => (
	typeof screenshot === 'string'
		? { src: screenshot, alt: `${app.name} screenshot`, caption: '' }
		: screenshot
));
const siteUrl = 'https://vtech-app.com';
const structuredData = {
	'@context': 'https://schema.org',
	'@type': 'SoftwareApplication',
	name: app.name,
	description: app.longDescription,
	url: `${siteUrl}/apps/${app.slug}/`,
	applicationCategory: 'UtilitiesApplication',
	operatingSystem: app.platform,
	softwareVersion: app.currentVersion,
	keywords: app.tags.join(', '),
	publisher: {
		'@type': 'Organization',
		name: 'VTech App',
		url: siteUrl,
		logo: `${siteUrl}/brand/vtech-logo.png`,
	},
	offers: {
		'@type': 'Offer',
		price: '0',
		priceCurrency: 'USD',
		availability: hasDownload ? 'https://schema.org/InStock' : 'https://schema.org/PreOrder',
		url: hasDownload ? app.downloadUrl : `${siteUrl}/apps/${app.slug}/`,
	},
};
---

<Layout
	title={`${app.name} | VTech App`}
	description={app.shortDescription}
	structuredData={structuredData}
>
	<article class="detail-shell">
		<header class="hero">
			<div>
				<p class="eyebrow">{app.platform} app</p>
				<h1>{app.name}</h1>
				<p>{app.shortDescription}</p>
				<div class="hero-actions">
					<span class="status">{app.status}</span>
					{hasDownload ? <a class="button primary" href={app.downloadUrl}>{isGitHub ? 'Download ZIP' : 'Download'}</a> : null}
					{hasChecksum ? <a class="button" href={app.checksumUrl}>Checksum</a> : null}
					{hasOlderVersions ? <a class="button" href="/olderversions/">Older versions</a> : null}
					{isGitHub ? <a class="button" href={app.sourceUrl} rel="noopener noreferrer" target="_blank">View on GitHub</a> : hasSource ? <a class="button" href={app.sourceUrl} rel="noopener noreferrer">View source</a> : null}
					<a class="button primary" href={app.donationUrl} rel="noopener noreferrer">Donate</a>
					<a class="button" href={`mailto:${app.supportEmail}`}>Contact support</a>
				</div>
			</div>
			<aside class="hero-panel">
				<AppIcon slug={app.slug} variant="lg" />
				<div class="meta-grid">
					<div class="meta-item"><span>Platform</span><strong>{app.platform}</strong></div>
					<div class="meta-item"><span>Status</span><strong>{app.status}</strong></div>
					<div class="meta-item"><span>Version</span><strong>{app.currentVersion}</strong></div>
					<div class="meta-item"><span>Release</span><strong>{app.releaseDate}</strong></div>
				</div>
				{
					hasDownload ? (
						<a class="button primary" href={app.downloadUrl}>{isGitHub ? 'Download ZIP' : 'Download'}</a>
					) : (
						<span class="button disabled" aria-disabled="true">Download Coming Soon</span>
					)
				}
				{isGitHub ? <a class="button" href={app.sourceUrl} rel="noopener noreferrer" target="_blank">View on GitHub</a> : null}
				{hasChecksum ? <a class="button" href={app.checksumUrl}>View checksum</a> : null}
				{hasOlderVersions ? <a class="button" href="/olderversions/">Older versions</a> : null}
			</aside>
		</header>

		<section class="two-column">
			<div class="card">
				<h2>About this app</h2>
				<p>{app.longDescription}</p>
				<ul class="tags" aria-label={`${app.name} tags`}>
					{app.tags.map((tag) => <li class="tag">{tag}</li>)}
				</ul>
			</div>
			<div class="card">
				<h2>Release status</h2>
				{
					hasDownload && isGitHub ? (
						<p>This app is distributed via its public GitHub repository. Clone or download the ZIP — no compiled binary is needed.</p>
					) : isGitHubRelease ? (
						<p>This Windows build is distributed through the official VTech App GitHub Release asset, with a SHA-256 checksum published for verification.</p>
					) : hasDownload && hasSource ? (
						<p>This app is available from its public source repository and official download link.</p>
					) : hasDownload ? (
						<p>This app is available from the official VTech App download link.</p>
					) : (
						<p>
							This app is in development. The download button will remain disabled until an official
							build is available from VTech App.
						</p>
					)
				}
			</div>
		</section>

		{features.length > 0 ? (
			<section>
				<div class="section-heading">
					<div>
						<p class="eyebrow">Capabilities</p>
						<h2>{featureHeading}</h2>
						<p>{featureIntro}</p>
					</div>
				</div>
				<div class="feature-strip app-feature-strip">
					{features.map((feature) => (
						<article class="feature-pill">
							<span>{feature}</span>
						</article>
					))}
				</div>
			</section>
		) : null}

		<section>
			<div class="section-heading">
				<div>
					<p class="eyebrow">Preview</p>
					<h2>Workflow preview</h2>
					<p>
						{screenshots.length > 0
							? 'Screenshots show the current app workflow and interface.'
							: 'Abstract interface previews show the type of workflow this utility is designed for.'}
					</p>
				</div>
			</div>
			{
				screenshots.length > 0 ? (
					<div class="gallery screenshot-gallery">
						{screenshots.map((screenshot) => (
							<figure class="screenshot-card">
								<img src={screenshot.src} alt={screenshot.alt} loading="lazy" />
								{screenshot.caption ? <figcaption>{screenshot.caption}</figcaption> : null}
							</figure>
						))}
					</div>
				) : (
					<div class="gallery preview-gallery">
						<article class="preview-card">
							<div class="preview-lines" aria-hidden="true"><span></span><span></span><span></span></div>
							<h3>Analyze</h3>
							<p>Review the relevant file, folder, storage, or permission data clearly.</p>
						</article>
						<article class="preview-card">
							<div class="preview-nodes" aria-hidden="true"><span></span><span></span><span></span></div>
							<h3>Act</h3>
							<p>Use focused utility workflows for practical administration tasks.</p>
						</article>
					</div>
				)
			}
		</section>

		<section class="two-column">
			<div class="card">
				<h2>Changelog</h2>
				<ul>
					{app.changelog.map((entry) => <li>{entry}</li>)}
				</ul>
			</div>
			{hasOlderVersions ? (
				<div class="card">
					<h2>Older versions</h2>
					<ul>
						{olderVersions.map((version) => (
							<li>
								<a href={version.downloadUrl}>{version.version}</a>
								{version.releaseDate ? ` - ${version.releaseDate}` : ''}
							</li>
						))}
					</ul>
					<a class="button" href="/olderversions/">View all older versions</a>
				</div>
			) : null}
			<div class="card">
				<h2>{isGitHub ? 'GitHub repository' : hasDownload ? 'Download details' : 'Source URL'}</h2>
				{
					isGitHub ? (
						<div class="github-section">
							<p>Clone with Git:</p>
							<pre class="clone-command"><code>git clone {cloneUrl}</code></pre>
							<div class="github-actions">
								<a class="button primary" href={app.sourceUrl} rel="noopener noreferrer" target="_blank">View on GitHub</a>
								{hasDownload ? <a class="button" href={app.downloadUrl}>Download ZIP</a> : null}
							</div>
						</div>
					) : hasSource ? (
						<a class="button" href={app.sourceUrl} rel="noopener noreferrer">View source</a>
					) : hasDownload ? (
						<div class="github-section">
							<p>Official release file:</p>
							<div class="github-actions">
								<a class="button primary" href={app.downloadUrl}>Download</a>
								{hasChecksum ? <a class="button" href={app.checksumUrl}>View checksum</a> : null}
							</div>
						</div>
					) : (
						<p class="meta">No public source URL is available yet.</p>
					)
				}
			</div>
		</section>
	</article>
</Layout>
