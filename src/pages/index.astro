---
import Layout from '../layouts/Layout.astro';
import AppCard from '../components/AppCard.astro';
import apps from '../data/apps.json';

const windowsApps = apps.filter((app) => app.platform === 'Windows');
---

<Layout
	title="VTech App | Practical Windows Utilities"
	description="VTech App builds focused tools for storage analysis, permission-safe file operations, and file-server auditing."
>
	<section class="hero home-hero">
		<div class="hero-copy">
			<p class="badge">Independent free software for practical system work</p>
			<h1>Practical Windows utilities for real-world system work.</h1>
			<p>
				VTech App builds focused tools for storage analysis, permission-safe file operations,
				and file-server auditing.
			</p>
			<div class="hero-actions">
				<a class="button primary" href="/apps/">Browse apps</a>
				<a class="button" href="/contact/">Send feedback</a>
			</div>
		</div>
	</section>

	<section>
		<div class="section-heading">
			<div>
				<p class="eyebrow">Featured Windows Utilities</p>
				<h2>Focused tools for common administration work.</h2>
			</div>
			<a class="button" href="/apps/">View all apps</a>
		</div>
		<div class="grid">
			{windowsApps.map((app) => <AppCard app={app} />)}
		</div>
	</section>

	<section>
		<div class="section-heading">
			<div>
				<p class="eyebrow">Why VTech App</p>
				<h2>Small utilities, clear purpose.</h2>
			</div>
		</div>
		<div class="feature-strip">
			<div class="feature-pill"><strong>No accounts</strong><span>No login, user database, or hosted account dependency.</span></div>
			<div class="feature-pill"><strong>Free software</strong><span>Independent utilities intended to stay accessible.</span></div>
			<div class="feature-pill"><strong>Admin workflows</strong><span>Built around practical filesystem and permission tasks.</span></div>
			<div class="feature-pill"><strong>Direct feedback</strong><span>Suggestions and support go straight to VTech App.</span></div>
		</div>
	</section>

	<section class="roadmap-grid">
		<article class="card roadmap-card">
			<p class="eyebrow">Windows</p>
			<h2>Windows utilities in development</h2>
			<p>
				The current catalog focuses on Windows tools for storage visibility, safer file
				operations, and file-server administration.
			</p>
			<a class="button" href="/apps/">Browse Windows apps</a>
		</article>
		<article class="card roadmap-card">
			<p class="eyebrow">Linux</p>
			<h2>Linux utilities planned</h2>
			<p>
				Linux tools are on the roadmap and will be listed only when real projects are ready to
				announce.
			</p>
			<span class="status">Coming Soon</span>
		</article>
	</section>

	<section class="final-cta">
		<div>
			<p class="eyebrow">Stay Connected</p>
			<h2>Help shape useful system utilities.</h2>
			<p>
				Send feature ideas, bug reports, and real administration problems you want VTech App
				tools to solve.
			</p>
		</div>
		<div class="actions">
			<a class="button primary" href="/apps/">Browse apps</a>
			<a class="button" href="/contact/">Contact</a>
			<a class="button" href="/donate/">Donate</a>
		</div>
	</section>
</Layout>
