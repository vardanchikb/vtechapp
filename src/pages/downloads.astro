---
import Layout from '../layouts/Layout.astro';
import apps from '../data/apps.json';

const windowsApps = apps.filter((app) => app.platform === 'Windows');
const linuxApps = apps.filter((app) => app.platform === 'Linux');
---

<Layout
	title="Downloads | VTech App"
	description="Official VTech App downloads, release status, versions, and safety information."
>
	<header class="page-heading">
		<p class="eyebrow">Release center</p>
		<h1>Official VTech App downloads.</h1>
		<p>
			VTech App releases are published only through official vtech-app.com links. Apps still in
			development remain marked Coming Soon.
		</p>
	</header>

	<section>
		<div class="section-heading">
			<div>
				<h2>Windows utilities</h2>
				<p>Release status for the current Windows utility catalog.</p>
			</div>
		</div>
		<div class="release-table" aria-label="Windows app release status">
			<div class="release-table-head">
				<span>App</span>
				<span>Platform</span>
				<span>Version</span>
				<span>Status</span>
				<span>Action</span>
			</div>
			{windowsApps.map((app) => (
				<article class="release-row">
					<div>
						<h3>{app.name}</h3>
						<p>{app.shortDescription}</p>
					</div>
					<span>{app.platform}</span>
					<span>{app.currentVersion}</span>
					<span class="status">{app.status}</span>
					<div class="actions">
						{app.downloadUrl ? (
							<a class="button primary" href={app.downloadUrl}>Download</a>
						) : (
							<span class="button disabled" aria-disabled="true">Coming Soon</span>
						)}
						<a class="button" href={`/apps/${app.slug}/`}>Details</a>
					</div>
				</article>
			))}
		</div>
	</section>

	<section>
		<div class="section-heading">
			<div>
				<h2>Linux utilities</h2>
				<p>Release status for the current Linux utility catalog.</p>
			</div>
		</div>
		<div class="release-table" aria-label="Linux app release status">
			<div class="release-table-head">
				<span>App</span>
				<span>Platform</span>
				<span>Version</span>
				<span>Status</span>
				<span>Action</span>
			</div>
			{linuxApps.map((app) => (
				<article class="release-row">
					<div>
						<h3>{app.name}</h3>
						<p>{app.shortDescription}</p>
					</div>
					<span>{app.platform}</span>
					<span>{app.currentVersion}</span>
					<span class="status">{app.status}</span>
					<div class="actions">
						{app.downloadUrl ? (
							<a class="button primary" href={app.downloadUrl}>Download ZIP</a>
						) : (
							<span class="button disabled" aria-disabled="true">Coming Soon</span>
						)}
						{app.sourceUrl ? (
							<a class="button" href={app.sourceUrl} rel="noopener noreferrer" target="_blank">View on GitHub</a>
						) : null}
						<a class="button" href={`/apps/${app.slug}/`}>Details</a>
					</div>
				</article>
			))}
		</div>
	</section>

	<section class="two-column">
		<article class="notice">
			<h2>Download safety</h2>
			<p>
				Official releases include site-hosted links, version status, changelog entries, and
				checksums when release files are published.
			</p>
		</article>
		<article class="notice">
			<h2>Linux apps from GitHub</h2>
			<p>
				Linux utilities are distributed via public GitHub repositories. Download the ZIP or clone
				the repo — instructions are on each app's detail page.
			</p>
		</article>
	</section>
</Layout>
