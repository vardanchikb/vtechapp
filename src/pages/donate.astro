---
import Layout from '../layouts/Layout.astro';

const donationUrl = 'https://ko-fi.com/vtechapp';
---

<Layout
	title="Donate | VTech App"
	description="Support VTech App development with a donation. VTech App software is free and independent."
>
	<header class="page-heading">
		<p class="eyebrow">Support development</p>
		<h1>Support VTech App.</h1>
		<p>
			VTech App builds practical free utilities for Windows users, technicians, and system
			administrators. Optional donations help cover development time, testing, hosting, code
			signing, and future releases while keeping the tools free.
		</p>
		<a class="button primary" href={donationUrl} rel="noopener noreferrer">Donate on Ko-fi</a>
	</header>

	<section class="grid">
		<article class="card">
			<h2>Development time</h2>
			<p>Donations help fund design, coding, documentation, and long-term maintenance.</p>
		</article>
		<article class="card">
			<h2>Testing</h2>
			<p>Practical utilities need careful testing across real Windows administration scenarios.</p>
		</article>
		<article class="card">
			<h2>Code signing and releases</h2>
			<p>Support helps cover release hosting, code signing, and future app distribution work.</p>
		</article>
	</section>

	<section class="notice">
		<h2>No payment processing on this site</h2>
		<p>
			VTech App links to Ko-fi for optional support. No payment processing code is embedded
			directly into this static website, and VTech App does not handle payment details.
		</p>
	</section>
</Layout>
