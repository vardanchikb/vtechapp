---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Privacy Policy | VTech App"
	description="Privacy policy for VTech App, a static software website with no accounts, login, or database."
>
	<header class="page-heading">
		<p class="eyebrow">Privacy</p>
		<h1>Privacy policy</h1>
		<p>
			VTech App is a static software website. It does not provide user registration, login, or a
			database-backed account system.
		</p>
	</header>

	<section class="stack">
		<article class="card">
			<h2>No accounts or login</h2>
			<p>
				This site does not create user accounts, does not offer login, and does not require
				registration to browse app information.
			</p>
		</article>
		<article class="card">
			<h2>Personal data</h2>
			<p>
				VTech App does not intentionally collect unnecessary personal data. If you submit the
				contact form, your submission is used only to respond to feedback or support requests.
			</p>
		</article>
		<article class="card">
			<h2>Analytics, donations, and downloads</h2>
			<p>
				Basic analytics may be added later to understand site usage. Donation links may go to
				third-party providers such as Buy Me a Coffee or Stripe. Download links may go to trusted
				external hosts such as GitHub Releases or Cloudflare R2 in the future.
			</p>
		</article>
	</section>
</Layout>
